# Auto detect text files and normalize line endings
* text=auto

# C# / .NET
*.cs text eol=lf
*.csproj text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.sln text eol=lf
*.slnx text eol=lf
*.slnf text eol=lf

# Config / scripts
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.config text eol=lf
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Docker
Dockerfile text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.apk binary
*.dll binary
*.exe binary
