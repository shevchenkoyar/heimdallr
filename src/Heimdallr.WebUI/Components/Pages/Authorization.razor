@page "/auth"
@layout AuthorizationLayout

<MudContainer MaxWidth="MaxWidth.False" Class="d-flex justify-center align-center min-h-screen">
    <MudItem xs="12" sm="8" md="6" lg="4">
        <MudPaper Class="pa-6" Elevation="6">
            <MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-4">Authorization</MudText>
            <MudTextField @bind-Value="Login" Label="Login" Variant="Variant.Outlined" Class="mb-3" FullWidth="true" />
            <MudTextField @bind-Value="Password" Label="Password" Variant="Variant.Outlined" InputType="InputType.Password" Class="mb-4" FullWidth="true" />
            <MudButton OnClick="Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true">Login</MudButton>
        </MudPaper>
    </MudItem>
</MudContainer>

@code {
    private string Login { get; set; } = string.Empty;
    private string Password { get; set; } = string.Empty;

    private void Submit() {}
}