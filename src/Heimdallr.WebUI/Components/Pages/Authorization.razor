@page "/auth"
@layout AuthorizationLayout

<MudCard Class="pa-4 w-50 mx-auto">
    <MudText Typo="Typo.h4" Color="Color.Primary" Class="fw-bold">Authorization</MudText>
    <MudTextField @bind-Value="Login" Label="Login" Variant="Variant.Outlined" FullWidth="true"/>
    <MudTextField @bind-Value="Password" Label="Password" Variant="Variant.Outlined" InputType="InputType.Password" FullWidth="true"/>
    <MudButton OnClick="Submit" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">Login</MudButton>
</MudCard>

@code {
    private string Login { get; set; } = string.Empty;
    private string Password { get; set; } = string.Empty;

    private void Submit()
    {
    }
}